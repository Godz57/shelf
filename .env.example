# Local development
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=

# Optional superuser bootstrap (used by some deploy hooks)
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=

# Production / Vercel (set in Vercel dashboard — do not commit real values)
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=<long random string>
# DATABASE_URL=postgres://...   # Neon / Vercel Postgres / Supabase
# CSRF_TRUSTED_ORIGINS=https://shelter-phi.vercel.app
# DJANGO_ALLOWED_HOSTS=.vercel.app,shelter-phi.vercel.app
# DJANGO_SECURE_SSL_REDIRECT=0   # leave 0 on Vercel (TLS terminated at edge)
# DJANGO_SECURE_HSTS_SECONDS=31536000
